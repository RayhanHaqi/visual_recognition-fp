# Secrets — never commit (example template is OK)
.kaggle/*
!.kaggle/kaggle.json.example
kaggle.json

# Data and model weights — local only; re-download / re-train on each machine
datasets/
datasets_tmp/
checkpoints/
*.pth
*.pt

# Download cache
KaggleNOAASeaLions.7z
noaa-fisheries-steller-sea-lion-population-count.zip
*.zip
*.7z

# Training logs and submissions — commit CSVs only (see docs/GIT_PROGRESS.md)
log/*
!log/.gitkeep
!log/*.csv

submission/*
!submission/.gitkeep
!submission/*.csv

report/*
!report/.gitkeep
notebooks/*
!notebooks/.gitkeep

__pycache__/
*.pyc
*.pyo
.DS_Store
.ipynb_checkpoints/
.pytest_cache/
