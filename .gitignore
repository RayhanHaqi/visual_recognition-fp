# Secrets — never commit (example template is OK)
.kaggle/*
!.kaggle/kaggle.json.example
kaggle.json
data_password.txt

# Data and model weights — local only; re-download / re-train on each machine
datasets/
datasets_tmp/
checkpoints/
*.pth
*.pt

# Download cache / archives (never commit)
KaggleNOAASeaLions.7z
TrainSmall2.7z
noaa-fisheries-steller-sea-lion-population-count.zip
*.7z
*.zip

# Training logs and submissions — commit CSVs only (see docs/GIT_PROGRESS.md)
log/*
!log/.gitkeep
!log/*.csv

submission/*
!submission/.gitkeep
!submission/*.csv

report/*
!report/.gitkeep
!report/report.tex
!report/README.md
!report/figure/**
notebooks/*
!notebooks/.gitkeep

# Vendored competition solutions (Phase 9 Lopuhin clone)
third_party/

__pycache__/
*.pyc
*.pyo
.DS_Store
.ipynb_checkpoints/
.pytest_cache/
